{{#> base_template}}
{{#*inline "content"}}

<div style="text-align: center; padding: 20px 0;">
  <h1 style="color: #2c3e50; font-size: 28px; margin: 0 0 10px 0;">🎓 Certificate Earned!</h1>
</div>

<p style="color: #34495e; font-size: 16px; line-height: 1.6;">Hi {{userName}},</p>

<p style="color: #34495e; font-size: 16px; line-height: 1.6;">
  Congratulations! You have successfully completed <strong>{{courseTitle}}</strong> on Logira Academy.
  Your hard work and dedication have earned you an official Certificate of Completion.
</p>

<div style="text-align: center; margin: 30px 0;">
  <a href="{{certificateUrl}}"
     style="background-color: #3498db;
            color: white;
            padding: 14px 32px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 600;
            display: inline-block;">
    View Certificate
  </a>
</div>

<div style="background-color: #f8f9fa;
            border-left: 4px solid #3498db;
            padding: 15px;
            margin: 20px 0;">
  <p style="margin: 5px 0; color: #5a6c7d; font-size: 14px;">
    <strong>Course:</strong> {{courseTitle}}
  </p>
  <p style="margin: 5px 0; color: #5a6c7d; font-size: 14px;">
    <strong>Issued:</strong> {{issueDate}}
  </p>
</div>

<p style="color: #34495e; font-size: 16px; line-height: 1.6;">
  You can access your certificate anytime through the link above or via your student dashboard.
  Feel free to share this achievement on your resume, LinkedIn profile, or professional portfolio.
</p>

<p style="color: #34495e; font-size: 16px; line-height: 1.6;">
  Thank you for choosing Logira Academy. We're proud of your accomplishment and look forward to
  supporting your continued learning journey!
</p>

{{/inline}}
{{/base_template}}
